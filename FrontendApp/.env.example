# Public runtime configuration. Only VITE_* vars are exposed to the client.
# NEVER put secrets here — anything VITE_* is bundled into the public client code.

# Base URL for the RBAC API (BackendApp).
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Human-readable app name, surfaced in the UI.
VITE_APP_NAME=ProjectX RBAC
